# ─────────────────────────────────────────────────────────────────────────────
# Environment Variables Template
# Copy to .env and fill in your API keys
# ─────────────────────────────────────────────────────────────────────────────

# AQICN API (https://aqicn.org/data-platform/token/)
AQICN_API_KEY=demo

# OpenWeatherMap (https://openweathermap.org/api)
OPENWEATHER_API_KEY=

# AWS Configuration
AWS_REGION=us-east-1
SAGEMAKER_ROLE_ARN=
S3_FEATURE_STORE_BUCKET=pearls-aqi-feature-store

# Target Location
TARGET_CITY=Sargodha
TARGET_LATITUDE=32.0836
TARGET_LONGITUDE=72.6711
TARGET_TIMEZONE=Asia/Karachi

# Model Configuration
FORECAST_HORIZON_HOURS=72
LOOKBACK_WINDOW_HOURS=72
AQI_ALERT_THRESHOLD=150

# LSTM Hyperparameters
LSTM_HIDDEN_SIZE=128
LSTM_NUM_LAYERS=2
LSTM_DROPOUT=0.3
LSTM_LEARNING_RATE=0.001
LSTM_EPOCHS=100
LSTM_BATCH_SIZE=64

# LightGBM Tuning
OPTUNA_N_TRIALS=50

# Server
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
LOG_LEVEL=INFO
